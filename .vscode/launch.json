{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Express with Nodemon",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["nodemon", "server.js"],
      "restart": true,
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/config.env",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
